SPLUNK_TOKEN=

# To encrypt your token at rest:
# 1. cd server && npx tsx src/encrypt-value.ts <your-master-key> "your-token"
# 2. Paste the enc:... value as SPLUNK_TOKEN above
# 3. On startup, the server will prompt you for the master key
#    (never stored on disk)

PORT=3001
